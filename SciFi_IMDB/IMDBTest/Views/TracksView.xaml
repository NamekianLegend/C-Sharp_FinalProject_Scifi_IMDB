<UserControl x:Class="A2_Chinook_EFandLINQ.Views.TracksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A2_Chinook_EFandLINQ.Views"
             xmlns:vm="clr-namespace:A2_Chinook_EFandLINQ.ViewModels"
             xmlns:conv="clr-namespace:A2_Chinook_EFandLINQ.Services"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:MillisecondsToTimeConverter x:Key="MsToTimeConv" />
    </UserControl.Resources>


    <StackPanel>
        <TextBlock Text="Tracks List." Style="{StaticResource mainHeaderStyle}"/>

        <!-- Sort Section -->
        <Grid Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <!-- Search by dropdown -->
                <TextBlock Text="Search by: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding SearchOptions}"
                  SelectedItem="{Binding SelectedSearch, Mode=TwoWay}"
                  Margin="0,0,16,0"
                  Width="165"/>

                <!-- Search box -->
                <TextBox Width="250"
                 VerticalContentAlignment="Center"
                 Padding="5,0"
                 Margin="0,0,16,0"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Sort -->
                <TextBlock Text="Sort by: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding SortOptions}"
                  SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                  Width="200"/>
            </StackPanel>

            <!-- Clear button on the right -->
            <Button Grid.Column="1"
                    Content="Clear"
                    HorizontalAlignment="Right"
                    Command="{Binding ClearCommand}"
                    ToolTip="Clear search and filters" />
        </Grid>



        <!-- Manual column headers -->
        <Border BorderBrush="{StaticResource TerminalAccent}" BorderThickness="0,0,0,1" Margin="5,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Track ID" FontWeight="Bold" Width="100"/>
                <TextBlock Text="Name" FontWeight="Bold" Width="1000" Padding="25,0"/>
                <TextBlock Text="Duration" FontWeight="Bold" Width="125" Padding="25,0"/>
            </StackPanel>
        </Border>
        <ListView ItemsSource="{Binding Tracks}" Height="464"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Expander>
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding TrackId}" Width="100"/>
                                <TextBlock Text="{Binding Name}" Width="1000"/>
                                <TextBlock Text="{Binding Milliseconds, Converter={StaticResource MsToTimeConv}, StringFormat='{}{0} mins'}" Width="125"/>
                            </StackPanel>
                        </Expander.Header>

                        <!-- Extra details shown when expanded -->
                        <StackPanel Margin="20,5,0,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Artist: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Album.Artist.Name}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Genre: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Genre.Name}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Album: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Album.Title}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Composer: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Composer}"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Summary bar — always visible below the list -->
        <StackPanel Orientation="Horizontal" Margin="5,4">
            <TextBlock Text="Showing "/>
            <TextBlock Text="{Binding Tracks.Count}"/>
            <TextBlock Text=" of "/>
            <TextBlock Text="{Binding TotalTracks}"/>
            <TextBlock Text=" tracks"/>
        </StackPanel>
    </StackPanel>
</UserControl>
