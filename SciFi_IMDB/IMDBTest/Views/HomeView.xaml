<UserControl x:Class="A2_Chinook_EFandLINQ.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A2_Chinook_EFandLINQ.Views"
             xmlns:vm="clr-namespace:A2_Chinook_EFandLINQ.ViewModels"
             mc:Ignorable="d">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Welcome message -->
            <TextBlock Text="Welcome to the Chinook App!"
                   Style="{StaticResource mainHeaderStyle}"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Browse music data using the buttons below or the navigation menu above."
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

            <!-- Navigation buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Artists"
                    Width="150"
                    Command="{Binding NavigateToArtistsCommand}"
                    ToolTip="Open Artists view"/>
                <Button Content="Albums"
                    Width="150"
                    Command="{Binding NavigateToAlbumsCommand}"
                    ToolTip="Open Albums view"/>
                <Button Content="Tracks"
                    Width="150"
                    Command="{Binding NavigateToTracksCommand}"
                    ToolTip="Open Tracks view"/>
                <Button Content="Catalog"
                    Width="150"
                    Command="{Binding NavigateToCatalogCommand}"
                    ToolTip="Open Catalog view"/>
                <Button Content="Orders"
                    Width="150"
                    Command="{Binding NavigateToOrdersCommand}"
                    ToolTip="Open Orders view"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
