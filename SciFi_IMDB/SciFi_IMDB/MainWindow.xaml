<Window x:Class="A2_Chinook_EFandLINQ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:A2_Chinook_EFandLINQ" 
        xmlns:views="clr-namespace:A2_Chinook_EFandLINQ.Views"
        mc:Ignorable="d"
        Title="Chinook App"
        Height="800"
        Width="1350">

    <DockPanel>
        <!-- Menu Section -->
        <Border Style="{DynamicResource sectionBorderStyle}" DockPanel.Dock="Top">
            <views:MainMenu />
        </Border>

        <!-- App Content Section fills remaining space -->
        <Border Style="{DynamicResource sectionBorderStyle}">
            <ContentControl Content="{Binding CurrentViewModel}"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"/>
        </Border>
    </DockPanel>
</Window>
