<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="IMDBConn"
             connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=IMDB;Integrated Security=True;Encrypt=True;Trust Server Certificate=True"
             providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>