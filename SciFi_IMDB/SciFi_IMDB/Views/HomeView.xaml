<UserControl x:Class="SciFi_IMDB.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SciFi_IMDB.Views"
             xmlns:vm="clr-namespace:SciFi_IMDB.ViewModels"
             mc:Ignorable="d">
    <Grid>



        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Welcome message -->
            <TextBlock Text="Welcome to the Sci-Fi IMDB Explorer!"
                   Style="{StaticResource mainHeaderStyle}"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Check out your Favourite Sci-Fi Tv and Movies Right Here! "
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

            <!-- Navigation buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Home"
                    Width="150"
                    Command="{Binding NavigateToHomeCommand}"
                    ToolTip="Go to Home"/>
                <Button Content="Movies"
                    Width="150"
                    Command="{Binding NavigateToMoviesCommand}"
                    ToolTip="Check out some movies!"/>
                <Button Content="Shows"
                    Width="150"
                    Command="{Binding NavigateToShowsCommand}"
                    ToolTip="Check out some shows!"/>
                <Button Content="Actors/Actresses"
                    Width="150"
                    Command="{Binding NavigateToActorsCommand}"
                    ToolTip="Check out your favourite actors/actresses!"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
