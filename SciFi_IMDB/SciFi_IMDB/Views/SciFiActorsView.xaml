<UserControl x:Class="SciFi_IMDB.Views.SciFiActorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SciFi_IMDB.Views"
             xmlns:vm="clr-namespace:SciFi_IMDB.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <TextBlock Text="Actors/Actresses" Style="{DynamicResource mainHeaderStyle}"/>

        <!-- Sort Section -->
        <Grid Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <!-- Search by dropdown -->
                <TextBlock Text="Search by: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding SearchOptions}"
                       SelectedItem="{Binding SelectedSearch, Mode=TwoWay}"
                       Margin="0,0,16,0"
                       Width="170"/>

                <!-- Search box -->
                <TextBox Width="250"
                      VerticalContentAlignment="Center"
                      Padding="5,0"
                      Margin="0,0,16,0"
                      Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Sort -->
                <TextBlock Text="Sort by: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding SortOptions}"
                       SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                       Width="200"/>
            </StackPanel>

            <!-- Clear button on the right -->
            <Button Grid.Column="1"
                 Content="Clear"
                 HorizontalAlignment="Right"
                 Command="{Binding ClearCommand}"
                 ToolTip="Clear search and filters" />
        </Grid>


        <!-- Manual column headers -->
        <Border BorderBrush="{DynamicResource TerminalAccent}" BorderThickness="0,0,0,1" Margin="5,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Actor ID" FontWeight="Bold" Width="125"/>
                <TextBlock Text="Name" FontWeight="Bold" Width="500" Padding="25,0"/>
            </StackPanel>
        </Border>
        <ListView ItemsSource="{Binding Actors}" Height="464" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Expander>
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="{Binding NameId}" Width="100" FontWeight="Bold" Foreground="Gray"/>
                                <TextBlock Text="{Binding PrimaryName}" Width="400" FontSize="14"/>
                            </StackPanel>
                        </Expander.Header>

                        <Expander.Content>
                            <StackPanel Margin="30,5,0,15">
                                <TextBlock Text="Known For (Sci-Fi):" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#007ACC"/>

                                <ItemsControl ItemsSource="{Binding KnownForTitles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Margin="0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander.Content>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Summary bar — always visible below the list -->
        <StackPanel Orientation="Horizontal" Margin="5,4">
            <TextBlock Text="Showing "/>
            <TextBlock Text="{Binding Actors.Count}"/>
            <TextBlock Text=" of "/>
            <TextBlock Text="{Binding TotalActors}"/>
            <TextBlock Text=" actors/actresses"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Previous"
                Command="{Binding PreviousPageCommand}"
                Margin="5"
                Padding="10,4"/>

            <TextBlock Text="{Binding Path=Actors.Count}" 
                VerticalAlignment="Center"
                Margin="10,0"/>

            <Button Content="Next"
                Command="{Binding NextPageCommand}"
                Margin="5"
                Padding="10,4"/>
        </StackPanel>

    </StackPanel>
</UserControl>
