<UserControl x:Class="A2_Chinook_EFandLINQ.Views.ArtistsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A2_Chinook_EFandLINQ.Views"
             xmlns:vm="clr-namespace:A2_Chinook_EFandLINQ.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    

    <StackPanel>
        <TextBlock Text="Artist List." Style="{DynamicResource mainHeaderStyle}"/>

        <!-- Sort Section -->
        <Grid Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <!-- Search by dropdown -->
                <TextBlock Text="Search by: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding SearchOptions}"
                          SelectedItem="{Binding SelectedSearch, Mode=TwoWay}"
                          Margin="0,0,16,0"
                          Width="170"/>

                <!-- Search box -->
                <TextBox Width="250"
                         VerticalContentAlignment="Center"
                         Padding="5,0"
                         Margin="0,0,16,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Sort -->
                <TextBlock Text="Sort by: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                          Width="200"/>
            </StackPanel>

            <!-- Clear button on the right -->
            <Button Grid.Column="1"
                    Content="Clear"
                    HorizontalAlignment="Right"
                    Command="{Binding ClearCommand}"
                    ToolTip="Clear search and filters" />
        </Grid>


        <!-- Manual column headers -->
        <Border BorderBrush="{DynamicResource TerminalAccent}" BorderThickness="0,0,0,1" Margin="5,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Artist ID" FontWeight="Bold" Width="125"/>
                <TextBlock Text="Name" FontWeight="Bold" Width="500" Padding="25,0"/>
                <TextBlock Text="Albums" FontWeight="Bold" Width="100" Padding="25,0"/>
                <TextBlock Text="Tracks" FontWeight="Bold" Width="100" Padding="25,0"/>
            </StackPanel>
        </Border>
        <ListView ItemsSource="{Binding Artists}" Height="464"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Expander>
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ArtistId}" Width="125"/>
                                <TextBlock Text="{Binding Name}" Width="500"/>
                                <TextBlock Text="{Binding Albums.Count}" Width="100"/>
                                <TextBlock Text="{Binding TrackCount}" Width="100"/>
                            </StackPanel>
                        </Expander.Header>

                        <!-- Albums shown when expanded -->
                        <ListView ItemsSource="{Binding Albums}" Margin="20,5,0,5">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Album ID" DisplayMemberBinding="{Binding AlbumId}"/>
                                    <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <!-- Summary bar — always visible below the list -->
        <StackPanel Orientation="Horizontal" Margin="5,4">
            <TextBlock Text="Showing "/>
            <TextBlock Text="{Binding Artists.Count}"/>
            <TextBlock Text=" of "/>
            <TextBlock Text="{Binding TotalArtists}"/>
            <TextBlock Text=" artists"/>
        </StackPanel>

    </StackPanel>
</UserControl>  