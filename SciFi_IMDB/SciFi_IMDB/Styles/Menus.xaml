<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Visible separator for menus and other places. Use a brighter color and a slightly larger height
     so it is visible against the dark background and inside menu popups. -->
    <Style TargetType="Separator">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Margin" Value="0,6" />
        <Setter Property="Height" Value="2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Grid HorizontalAlignment="Stretch">
                        <!-- Use TerminalText (bright green) with reduced opacity so separator stands out -->
                        <Border Height="2" Background="{StaticResource TerminalText}" Opacity="0.35" HorizontalAlignment="Stretch"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu-specific separator style: menus use a special resource key for separators inside menus.
     This ensures separators in Menu and MenuItem popups follow the terminal theme. -->
    <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Margin" Value="8,6" />
        <Setter Property="Height" Value="2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="2" Background="{StaticResource TerminalText}" Opacity="0.35" HorizontalAlignment="Stretch" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ContextMenu / submenu background styling to ensure dropdown menus match theme -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="BorderBrush" Value="{StaticResource TerminalIconBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Menu styling to match terminal theme -->
    <Style TargetType="Menu" BasedOn="{StaticResource TerminalBase}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Custom MenuItem template so submenu popup background uses terminal colors -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Margin" Value="0,0,16,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter ContentSource="Icon" VerticalAlignment="Center" Margin="4,0"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>

                        <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsSubmenuOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade" StaysOpen="False">
                            <Border Background="{StaticResource TerminalPanel}" BorderBrush="{StaticResource TerminalIconBorder}" BorderThickness="1" CornerRadius="2">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource TerminalAccent}" />
                            <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>