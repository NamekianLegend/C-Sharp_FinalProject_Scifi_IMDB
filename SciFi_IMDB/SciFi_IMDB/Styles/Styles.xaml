<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Split styles into smaller, focused dictionaries for maintainability.
     This file simply merges the separate resource dictionaries so existing
     references to /Styles/Styles.xaml continue to work. -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Styles/ThemeColors.xaml" />
        <ResourceDictionary Source="/Styles/Common.xaml" />
        <ResourceDictionary Source="/Styles/Controls.xaml" />
        <ResourceDictionary Source="/Styles/Menus.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>