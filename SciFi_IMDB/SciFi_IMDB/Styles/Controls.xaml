<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="TextBox" BasedOn="{StaticResource TerminalBase}">
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="BorderBrush" Value="{StaticResource TerminalIconBorder}" />
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource TerminalBase}">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
    </Style>

    <Style TargetType="ListView" BasedOn="{StaticResource TerminalBase}"/>

    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{StaticResource TerminalAccent}" />
        <Setter Property="Padding" Value="5"/>
    </Style>

    <Style x:Key="TerminalListViewItem" TargetType="ListViewItem">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource TerminalAccent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Calendar">
        <Setter Property="Background" Value="{StaticResource TerminalBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="BorderBrush" Value="{StaticResource TerminalIconBorder}" />
    </Style>

    <Style TargetType="DatePickerTextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TerminalText}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ComboBox: keep default control template for native dropdown behavior,
     but apply terminal color brushes so appearance matches the theme. -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource TerminalBase}">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="BorderBrush" Value="{StaticResource TerminalIconBorder}" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.ColumnSpan="2"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="2" />

                        <ContentPresenter Grid.Column="0"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  VerticalAlignment="Center"
                                  Margin="6,2,2,2"
                                  IsHitTestVisible="False" />

                        <ToggleButton Grid.ColumnSpan="2"
          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
          Focusable="False"
          BorderThickness="0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Path Grid.Column="1"
                      Width="8" Height="6"
                      Stretch="Uniform"
                      Fill="{StaticResource TerminalText}"
                      Data="M 0 0 L 4 4 L 8 0 Z"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      IsHitTestVisible="False" />

                        <Popup Name="PART_Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Fade"
                       Grid.ColumnSpan="2">
                            <Border Background="{StaticResource TerminalPanel}"
                            BorderBrush="{StaticResource TerminalIconBorder}"
                            BorderThickness="1"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                                <ScrollViewer CanContentScroll="True">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderBrush" Value="{StaticResource TerminalIconBorder}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource TerminalAccent}" />
                <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource TerminalAccent}" />
                <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>