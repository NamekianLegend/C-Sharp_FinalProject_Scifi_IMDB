<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ToolTip style to ensure consistent background, border and text -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="BorderBrush" Value="{StaticResource TerminalIconBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Placement" Value="Mouse" />
    </Style>

    <!--Everything is based on this-->
    <Style x:Key="TerminalBase" TargetType="Control">
        <Setter Property="Background" Value="{StaticResource TerminalBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource TerminalAccent}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}"/>
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Ensure dropdown content scroll areas and scrollbars match theme -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource TerminalPanel}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="Width" Value="12" />
    </Style>

    <!-- Default TextBlock style so text is visible on dark terminal background -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TerminalText}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="4" />
    </Style>

    <!-- Project-specific named styles preserved and adjusted to match theme -->
    <Style x:Key="mainHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="Foreground" Value="{StaticResource TerminalText}"/>
        <Setter Property="Padding" Value="5" />
        <Setter Property="Margin" Value="5" />
    </Style>

    <Style x:Key="logoImageStyle" TargetType="Image">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="Margin" Value="2" />
    </Style>

    <!-- Small icon style: recolor icons using OpacityMask so they match the terminal text color -->
    <Style x:Key="iconImageStyle" TargetType="Image">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
        <Setter Property="OpacityMask" Value="{StaticResource TerminalText}" />
    </Style>

    <!-- Keep section border used by MainWindow but style it to match the terminal theme -->
    <Style x:Key="sectionBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource TerminalAccent}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="Background" Value="{StaticResource TerminalIconBackground}" />
    </Style>

    <Style x:Key="InspectorBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource TerminalText}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource TerminalIconBackground}" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>