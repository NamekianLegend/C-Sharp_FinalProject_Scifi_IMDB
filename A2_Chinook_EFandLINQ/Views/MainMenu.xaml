<UserControl x:Class="A2_Chinook_EFandLINQ.Views.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A2_Chinook_EFandLINQ.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
     <DockPanel>
        <!-- Dropdown menu on the left -->
        <Menu DockPanel.Dock="Left" Height="45" VerticalContentAlignment="Center">
            <!-- File Menu-->
            <MenuItem Header="File">
                <MenuItem Header="Exit"
                          Command="{Binding ExitCommand}"
                          ToolTip="Exit the application.">
                    <MenuItem.Icon>
                        <Image Source="/Assets/exit.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            
            <!-- Navigate Menu-->
            <MenuItem Header="Navigate">
                <MenuItem Header="Home"
                          Command="{Binding NavigateToHomeCommand}"
                          ToolTip="Return to the application home screen.">
                    <MenuItem.Icon>
                        <Image Source="/Assets/home.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Catalog"
                          Command="{Binding NavigateToCatalogCommand}"
                          ToolTip="View and filter the music catalog.">
                    <MenuItem.Icon>
                        <Image Source="/Assets/filter.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Orders"
                          Command="{Binding NavigateToOrdersCommand}"
                          ToolTip="View and filter the customers orders.">
                    <MenuItem.Icon>
                        <Image Source="/Assets/order.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Artists"
                          Command="{Binding NavigateToArtistsCommand}"
                          ToolTip="View and search the list of all musical artists.">
                    <MenuItem.Icon>
                        <Image Source="/Assets/artists.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Tracks"
                          Command="{Binding NavigateToTracksCommand}"
                          ToolTip="Explore individual song tracks and pricing.">
                    <MenuItem.Icon>
                        <Image Source="/Assets/tracks.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Albums"
                          Command="{Binding NavigateToAlbumsCommand}"
                          ToolTip="Browse the collection of music albums.">
                    <MenuItem.Icon>
                        <Image Source="/Assets/albums.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Go Back"
                          Command="{Binding NavigateBackCommand}"
                          ToolTip="Navigate back to the previous page.">
                    <MenuItem.Icon>
                        <Image Source="/Assets/back.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Nav buttons on the right -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Command="{Binding NavigateToHomeCommand}" Margin="4,0" ToolTip="Home">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/home.png" Width="16" Height="16" Margin="0,0,4,0"/>
                    <TextBlock Text="Home"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding NavigateToOrdersCommand}" Margin="4,0" ToolTip="Home">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/order.png" Width="16" Height="16" Margin="0,0,4,0"/>
                    <TextBlock Text="Orders"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding NavigateToCatalogCommand}" Margin="4,0" ToolTip="Home">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/filter.png" Width="16" Height="16" Margin="0,0,4,0"/>
                    <TextBlock Text="Catalog"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding NavigateToArtistsCommand}" Margin="4,0" ToolTip="Artists">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/artists.png" Width="16" Height="16" Margin="0,0,4,0"/>
                    <TextBlock Text="Artists"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding NavigateToAlbumsCommand}" Margin="4,0" ToolTip="Albums">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/albums.png" Width="16" Height="16" Margin="0,0,4,0"/>
                    <TextBlock Text="Albums"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding NavigateToTracksCommand}" Margin="4,0" ToolTip="Tracks">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/tracks.png" Width="16" Height="16" Margin="0,0,4,0"/>
                    <TextBlock Text="Tracks"/>
                </StackPanel>
            </Button>

            <!-- Back button separated by a small gap -->
            <Button Command="{Binding NavigateBackCommand}" Margin="16,0,4,0" ToolTip="Go Back">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/back.png" Width="16" Height="16" Margin="0,0,4,0"/>
                    <TextBlock Text="Back"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </DockPanel>
    
</UserControl>
